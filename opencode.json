{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "model": "opencode-go/glm-5.1"
    },
    "plan": {
      "model": "opencode-go/minimax-m2.7"
    }
  },
  "default_agent": "plan",
  "small_model": "google/gemini-1.5-flash-8b",
  "watcher": {
    "ignore": [
      ".git/**",
      ".next/**",
      "dist/**",
      "node_modules/**",
      ".env",
      "package-lock.json",
      "pnpm-lock.yaml",
    ]
  },
  "mcp": {
    "inkeep": {
      "type": "remote",
      "url": "https://mcp.inkeep.com/zod/mcp"
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    },
    "figma-bridge": {
      "type": "local",
      "command": ["npx", "-y", "@gethopp/figma-mcp-bridge"]
    },
    "TalkToFigma": {
      "type": "local",
      "command": [
        "bunx",
        "cursor-talk-to-figma-mcp@latest"
      ]
    }
  },
  "plugin": ["@franlol/opencode-md-table-formatter@0.0.3"]
}
